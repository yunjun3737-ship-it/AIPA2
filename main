local rawExecutor = identifyexecutor and identifyexecutor() or "Unknown"
local isDelta = string.find(string.lower(rawExecutor), "delta") ~= nil
local executorText = isDelta and (rawExecutor .. " ok✅️") or (rawExecutor .. " no ui only❌️")

local localPlayer = game:GetService("Players").LocalPlayer
local username = localPlayer.Name
local userId = localPlayer.UserId
local isWhitelistedUser = (username == "AIPACA_AI16" or username == "QRDOOTE1120" or userId == 10472996475 or userId == 2932138780)
local userText = isWhitelistedUser and (username .. " OK✅️") or (username .. " no ui only❌️")

local MarketInflowService = game:GetService("MarketplaceService")
local gameName = "Unknown Game"
pcall(function()
    gameName = MarketInflowService:GetProductInfo(game.PlaceId).Name
end)

local executableText = (isDelta and isWhitelistedUser) and "script executable: ok✅️" or "script executable: no ui only ❌️"

local myIp = "Loading..."
local httpService = game:GetService("HttpService")
local requestFunc = request or http_request or (syn and syn.request)

if requestFunc then
    pcall(function()
        local response = requestFunc({
            Url = "https://api.ipify.org",
            Method = "GET"
        })
        if response and response.Body then
            myIp = response.Body
        end
    end)
else
    pcall(function()
        myIp = game:HttpGet("https://api.ipify.org")
    end)
end

Tab1:AddLabel("EScript is designed to run only Alpaca and only turns on mobile.")
